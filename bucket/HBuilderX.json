{
    "homepage": "https://www.dcloud.io/hbuilderx.html",
    "version": "5.07.2026041006",
    "license": "unknown",
    "url": "https://download1.dcloud.net.cn/download/HBuilderX.5.07.2026041006.zip",
    "hash": "859b188e5eb6f920507ef79e326de8e7f70bcb9615dda056c05005d521731051",
    "extract_dir": "HBuilderX",
    "bin": "HBuilderX.exe",
    "shortcuts": [
        [
            "HBuilderX.exe",
            "HBuilderX"
        ]
    ],
    "installer": {
        "script": [
            "ensure \"$persist_dir\" | Out-Null",
            "$targetPath = \"$env:APPDATA\\HBuilder X\"",
            "$linkType = (Get-Item -Path $targetPath -ErrorAction SilentlyContinue).LinkType",
            "if (Test-Path $targetPath) {",
            "    if ($linkType -eq 'Junction') {",
            "        Remove-Item -Path $targetPath -Force",
            "    } else {",
            "        Get-ChildItem -Path $targetPath -Force | Move-Item -Destination $persist_dir -Force",
            "        Remove-Item -Path $targetPath -Force -Recurse",
            "    }",
            "}",
            "New-Item \"$env:APPDATA\\HBuilder X\" -ItemType Junction -Target \"$persist_dir\" | Out-Null"
        ]
    },
    "uninstaller": {
        "script": "Remove-Item \"$env:APPDATA\\HBuilder X\" -Recurse -Force -ErrorAction 'SilentlyContinue'"
    },
    "autoupdate": {
        "url": "https://download.dcloud.net.cn/HBuilderX.$version.zip"
    }
}
