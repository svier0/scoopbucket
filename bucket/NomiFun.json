    "url": "https://github.com/nomifun/nomifun-tauri/releases/download/v0.2.24/NomiFun_0.2.24_x64-setup.exe#/dl.7z",
    "hash": "0074069a53c3a8c3c3844814a4013eeb44ff1916e807b7b37cfa9db6d0a9f5cf",
    "installer": {
        "script": [
            "Get-ChildItem \"$dir\" -Directory | Where-Object Name -in '$PLUGINSDIR' | Remove-Item -Recurse -Force",
            "",
            "# 将运行时目录重定向到 persist_dir，避免污染系统",
            "function New-Junction { param([string]$Path, [string]$Target)",
            "    if (Test-Path $Path) {",
            "        $item = Get-Item $Path",
            "        if (-not $item.LinkType) {",
            "            if (Test-Path \"$Path\\*\") { Move-Item \"$Path\\*\" \"$Target\\\" -Force }",
            "            Remove-Item $Path -Recurse -Force",
            "        } else { Remove-Item $Path -Recurse -Force }",
            "    }",
            "    New-Item -ItemType Junction -Path $Path -Target $Target -Force | Out-Null",
            "}",
            "New-Item -ItemType Directory -Path \"$persist_dir\\localappdata\" -Force | Out-Null",
            "New-Junction \"$env:LOCALAPPDATA\\NomiFun\" \"$persist_dir\\localappdata\"",
            ""
        ]
    },
    "uninstaller": {
        "script": [
            "@( \"$env:LOCALAPPDATA\\NomiFun\" ) | ForEach-Object {",
            "    if (Test-Path $_) {",
            "        $item = Get-Item $_",
            "        if ($item.LinkType -eq 'Junction') { Remove-Item $_ -Recurse -Force }",
            "    }",
            "}"
        ]
    },
    "bin": "nomifun-desktop.exe",
    "shortcuts": [
        [
            "nomifun-desktop.exe",
            "NomiFun"
        ]
    ],
    "checkver": {
        "github": "https://github.com/nomifun/nomifun-tauri"
    },
    "autoupdate": {
        "url": "https://github.com/nomifun/nomifun-tauri/releases/download/v$version/NomiFun_$version_x64-setup.exe#/dl.7z",
        "hash": {
            "url": "https://api.github.com/repos/nomifun/nomifun-tauri/releases/tags/v$version",
            "regex": "\"name\":\\s*\"NomiFun_$version_x64-setup\\.exe\"[^}]*\"digest\":\\s*\"sha256:([a-f0-9]{64})\""
        }
    }
}
