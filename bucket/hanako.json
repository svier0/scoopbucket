{
    "version": "0.407.15",
    "description": "Hanako desktop agent",
    "homepage": "https://github.com/liliMozi/openhanako",
    "license": "Apache-2.0",
    "url": "https://github.com/liliMozi/openhanako/releases/download/v0.407.15/HanaAgent-0.407.15-Windows-x64.exe#/dl.7z",
    "hash": "c9b88d9bce7165923e6ba6bd6d16fd18ac47a6e2dd4e6672fa6fb96a8d08ac1f",
    "installer": {
        "script": [
            "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
            "Get-ChildItem \"$dir\" -Directory | Where-Object Name -in '$PLUGINSDIR','$R0' | Remove-Item -Recurse -Force",
            "Remove-Item \"$dir\\uninstallerIcon.ico\" -Force -ErrorAction SilentlyContinue",
            "",
            "# 将运行时目录重定向到 persist_dir，避免污染系统",
            "if(Test-Path \"$env:USERPROFILE\\.hanako\\.ephemeral\"){ Remove-Item -LiteralPath \"\\\\?\\$env:USERPROFILE\\.hanako\\.ephemeral\" -Recurse -Force }",
            "function New-Junction { param([string]$Path, [string]$Target)",
            "    if (Test-Path $Path) {",
            "        $item = Get-Item $Path",
            "        if (-not $item.LinkType) {",
            "            if (Test-Path \"$Path\\*\") { Move-Item \"$Path\\*\" \"$Target\\\" -Recurse -Force }",
            "            Remove-Item $Path -Recurse -Force",
            "        } else { Remove-Item $Path -Recurse -Force }",
            "    }",
            "    New-Item -ItemType Junction -Path $Path -Target $Target -Force | Out-Null",
            "}",
            "New-Item -ItemType Directory -Path \"$persist_dir\\appdata\\Hanako\" -Force | Out-Null",
            "New-Item -ItemType Directory -Path \"$persist_dir\\localappdata\\hanako-updater\" -Force | Out-Null",
            "New-Item -ItemType Directory -Path \"$persist_dir\\home\\.hanako\" -Force | Out-Null",
            "New-Junction \"$env:APPDATA\\Hanako\" \"$persist_dir\\appdata\\Hanako\"",
            "New-Junction \"$env:LOCALAPPDATA\\hanako-updater\" \"$persist_dir\\localappdata\\hanako-updater\"",
            "New-Junction \"$env:USERPROFILE\\.hanako\" \"$persist_dir\\home\\.hanako\""
        ]
    },
    "uninstaller": {
        "script": [
            "@(\"$env:APPDATA\\Hanako\", \"$env:LOCALAPPDATA\\hanako-updater\", \"$env:USERPROFILE\\.hanako\") | ForEach-Object {",
            "    if (Test-Path $_) {",
            "        $item = Get-Item $_",
            "        if ($item.LinkType -eq 'Junction') { Remove-Item $_ -Force }",
            "    }",
            "}"
        ]
    },
    "bin": "HanaAgent.exe",
    "shortcuts": [
        [
            "HanaAgent.exe",
            "Hanako"
        ]
    ],
    "checkver": {
        "github": "https://github.com/liliMozi/openhanako"
    },
    "autoupdate": {
        "url": "https://github.com/liliMozi/openhanako/releases/download/v$version/HanaAgent-$version-Windows-x64.exe#/dl.7z",
        "hash": {
            "url": "https://api.github.com/repos/liliMozi/openhanako/releases/tags/v$version",
            "regex": "\"name\":\\s*\"HanaAgent-$version-Windows-x64\\.exe\"[^}]*\"digest\":\\s*\"sha256:([a-f0-9]{64})\""
        }
    }
}
